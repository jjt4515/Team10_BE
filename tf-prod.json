{
  "containerDefinitions": [
    {
      "name": "poomasi-container",
      "image": "010928195795.dkr.ecr.ap-northeast-2.amazonaws.com/poomasi-ecr",
      "portMappings": [
        {
          "name": "poomasi-container-8080-tcp",
          "containerPort": 8080,
          "hostPort": 0,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "TZ",
          "value": "Asia/Seoul"
        }
      ],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ecs-task-definition",
          "mode": "non-blocking",
          "awslogs-create-group": "true",
          "max-buffer-size": "25m",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "systemControls": [] 
    }
  ],
  "family": "ecs-task-definition",
  "taskRoleArn": "arn:aws:iam::010928195795:role/ecsTaskExecutionRole",
  "executionRoleArn": "arn:aws:iam::010928195795:role/ecsTaskExecutionRole",
  "networkMode": "bridge",
  "volumes": [],
  "placementConstraints": [],
  "cpu": "128",
  "memory": "256",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}